@model RecipeWebsite.Models.Recipe

@{
    ViewBag.Title = "Details";
}

<h2>Details</h2>

<div>
    <h4>Recipe</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Category.CategoryName)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Category.CategoryName)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.User.Username)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.User.Username)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Title)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Description)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.ImageUrl)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.ImageUrl)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.PrepTime)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.PrepTime)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.CookTime)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.CookTime)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>

    </dl>
</div>
<hr />
<div class="row">
    <div class="col-md-6">
        <h3>Nguyên liệu</h3>
        <a href="@Url.Action("Create", "Ingredients", new { recipeId = Model.RecipeId })" class="btn btn-sm btn-success mb-2">
            + Thêm nguyên liệu
        </a>
        <ul class="list-group" style="margin-top: 15px;">
            @foreach (var item in Model.Ingredients)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @item.Name
                    <span class="badge badge-primary badge-pill">@item.Quantity</span>
                </li>
            }
        </ul>
    </div>

    <div class="col-md-6">
        <h3>Các bước thực hiện</h3>
        <a href="@Url.Action("Create", "Steps", new { recipeId = Model.RecipeId })" class="btn btn-sm btn-info mb-2">
            + Thêm bước làm
        </a>
        <ol class="list-group list-group-numbered" style="margin-top: 15px;">
            @foreach (var step in Model.Steps.OrderBy(s => s.StepNumber))
            {
                <li class="list-group-item">
                    <strong>Bước @step.StepNumber:</strong> @step.Instruction
                </li>
            }
        </ol>
    </div>
</div>
<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.RecipeId }) |
    @Html.ActionLink("Back to List", "Index")
</p>
